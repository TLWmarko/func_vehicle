	obj.lip = 16;
	obj.max_forward_speed = 280;
	obj.max_reverse_speed = 280;
	obj.max_roll_speed = 2000;
	obj.accelerate_forward = 2000;
	obj.accelerate_reverse = 2000;
	obj.accelerate_roll = 350;
	obj.max_turn = -45;
